<!doctype html>
<html lang="ru">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link rel="icon" type="image/png" href="/img/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/product.css">
    <link rel="stylesheet" href="/css/footer.css">
</head>

<body>
    <%- include('../partials/header') %>

        <main class="prodWrap">
            <div class="container">

                <div style="margin-bottom: 24px;">
                    <a href="/menu"
                        style="display: inline-block; padding: 10px 20px; background: #f0f0f0; border-radius: 50px; text-decoration: none; color: #333; font-weight: 600; font-size: 14px; transition: 0.2s;">
                        ← Вернуться в меню
                    </a>
                </div>

                <div class="prodTop">
                    <div class="prodCat">
                        <%= product.category_title %>
                    </div>
                    <h1 class="prodTitle">
                        <%= product.name %>
                    </h1>
                    <% if (product.description) { %>
                        <p class="prodDesc">
                            <%= product.description %>
                        </p>
                        <% } %>
                </div>

                <section class="prodCard">
                    <div class="prodImgBox">
                        <img class="prodImg" src="<%= product.image_url || '/img/products/placeholder.png' %>"
                            alt="<%= product.name %>">
                    </div>

                    <div class="nutri">
                        <div class="nutriHead">
                            <div class="nutriTitle">ПИЩЕВАЯ ЦЕННОСТЬ</div>
                            <a class="nutriLink" href="/calories">в калькулятор →</a>
                        </div>

                        <% if (product.weight_g || product.calories) { %>
                            <div style="margin-top: 15px; margin-bottom: 15px; color: #555;">
                                <b>Вес:</b>
                                <%= product.weight_g ? product.weight_g + ' г' : '—' %>
                            </div>
                            <div
                                style="display: flex; gap: 15px; margin-bottom: 20px; background: #f9f9f9; padding: 16px; border-radius: 12px; font-size: 14px; text-align: center; border: 1px solid #eee;">
                                <div style="flex: 1;">
                                    <div
                                        style="color: #888; font-size: 12px; text-transform: uppercase; margin-bottom: 6px;">
                                        Белки</div><b style="font-size: 18px;">
                                        <%= product.proteins || 0 %> г
                                    </b>
                                </div>
                                <div style="flex: 1;">
                                    <div
                                        style="color: #888; font-size: 12px; text-transform: uppercase; margin-bottom: 6px;">
                                        Жиры</div><b style="font-size: 18px;">
                                        <%= product.fats || 0 %> г
                                    </b>
                                </div>
                                <div style="flex: 1;">
                                    <div
                                        style="color: #888; font-size: 12px; text-transform: uppercase; margin-bottom: 6px;">
                                        Углеводы</div><b style="font-size: 18px;">
                                        <%= product.carbs || 0 %> г
                                    </b>
                                </div>
                                <div style="flex: 1; border-left: 1px solid #ddd;">
                                    <div
                                        style="color: #E30613; font-size: 12px; text-transform: uppercase; margin-bottom: 6px;">
                                        Ккал</div><b style="color: #E30613; font-size: 20px;">
                                        <%= product.calories || 0 %>
                                    </b>
                                </div>
                            </div>
                            <% } else { %>
                                <div style="color: #888; margin-top: 15px;">Пищевая ценность не указана</div>
                                <% } %>

                                    <% if (typeof addons !=='undefined' && addons && addons.length> 0) { %>
                                        <div style="margin-top: 24px; padding-top: 20px; border-top: 1px solid #eee;">
                                            <div style="font-weight: 700; margin-bottom: 12px; font-size: 16px;">
                                                Добавить к блюду:</div>
                                            <% addons.forEach(addon=> { %>
                                                <label
                                                    style="display: flex; justify-content: space-between; align-items: center; cursor: pointer; padding: 10px 0; border-bottom: 1px dashed #f5f5f5;">
                                                    <div style="display: flex; align-items: center; gap: 10px;">
                                                        <input type="checkbox" class="addon-checkbox"
                                                            value="<%= addon.id %>" data-price="<%= addon.price %>"
                                                            style="width: 18px; height: 18px; accent-color: #E30613; cursor: pointer;">
                                                        <span style="font-size: 15px;">
                                                            <%= addon.name %>
                                                        </span>
                                                    </div>
                                                    <span style="font-weight: 600; font-size: 15px;">+<%=
                                                            Number(addon.price).toFixed(0) %> ₽</span>
                                                </label>
                                                <% }) %>
                                        </div>
                                        <% } %>

                                            <div
                                                style="display: flex; align-items: center; justify-content: space-between; margin-top: 24px; padding-top: 20px; border-top: 2px solid #f5f5f5;">
                                                <div class="prodPrice" style="margin: 0; padding: 0; border: none;">
                                                    <div class="muted">Итого</div>
                                                    <div class="prodPrice__n"
                                                        style="font-size: 32px; font-weight: 800;">
                                                        <span id="finalPrice" data-base-price="<%= product.price %>">
                                                            <%= Number(product.price).toFixed(0) %>
                                                        </span> ₽
                                                    </div>
                                                </div>

                                                <button class="add-to-cart-btn" data-id="<%= product.id %>"
                                                    style="background: #E30613; color: white; border: none; padding: 16px 36px; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; transition: 0.2s;">
                                                    В корзину
                                                </button>
                                            </div>
                    </div>
                </section>

                <% if (related.length) { %>
                    <section class="rel">
                        <h2 class="relTitle">Похожие блюда</h2>
                        <div class="relGrid">
                            <% related.forEach(r=> { %>
                                <a class="relItem" href="/product/<%= r.id %>">
                                    <img src="<%= r.image_url || '/img/products/placeholder.png' %>"
                                        alt="<%= r.name %>">
                                    <div>
                                        <%= r.name %>
                                    </div>
                                </a>
                                <% }) %>
                        </div>
                    </section>
                    <% } %>

            </div>
        </main>

        <div class="side-cart-overlay" id="sideCartOverlay"></div>
        <aside class="side-cart" id="sideCart"
            style="position: fixed; top: 0; right: -420px; width: 100%; max-width: 400px; height: 100vh; background: #fff; z-index: 999; display: flex; flex-direction: column; transition: right 0.3s ease; box-shadow: -10px 0 30px rgba(0,0,0,0.1);">
            <div class="side-cart__header"
                style="padding: 20px; border-bottom: 1px solid rgba(0,0,0,0.08); display: flex; justify-content: space-between; align-items: center;">
                <h2 style="margin:0; font-size: 24px;">Ваш заказ</h2>
                <button class="side-cart__close" id="closeSideCartBtn"
                    style="background: transparent; border: none; font-size: 20px; cursor: pointer; color: #666;">✕</button>
            </div>
            <div class="side-cart__body" id="sideCartBody" style="flex-grow: 1; overflow-y: auto; padding: 20px;">
                <div style="text-align:center; margin-top: 40px; color: #666;">Загрузка...</div>
            </div>
            <div class="side-cart__footer"
                style="padding: 20px; background: #fdfdfd; border-top: 1px solid rgba(0,0,0,0.08);">
                <div
                    style="display: flex; justify-content: space-between; font-weight: 700; font-size: 20px; margin-bottom: 16px;">
                    <span>Итого:</span>
                    <span id="sideCartTotal">0 ₽</span>
                </div>
                <a href="/cart"
                    style="display: block; background: #E30613; color: white; padding: 14px; text-align: center; border-radius: 8px; text-decoration: none; font-weight: 600;">Оформить
                    заказ</a>
            </div>
        </aside>

        <%- include('../partials/footer') %>

            <script src="/js/side-cart.js"></script>

            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    const checkboxes = document.querySelectorAll('.addon-checkbox');
                    const priceEl = document.getElementById('finalPrice');
                    const basePrice = parseFloat(priceEl ? priceEl.getAttribute('data-base-price') : 0);

                    // Динамический пересчет цены
                    checkboxes.forEach(box => {
                        box.addEventListener('change', () => {
                            let currentTotal = basePrice;
                            document.querySelectorAll('.addon-checkbox:checked').forEach(checkedBox => {
                                currentTotal += parseFloat(checkedBox.getAttribute('data-price'));
                            });
                            if (priceEl) priceEl.innerText = currentTotal.toFixed(0);
                        });
                    });

                    // Отправка в корзину с учетом добавок
                    const addToCartBtn = document.querySelector('.add-to-cart-btn');
                    if (addToCartBtn) {
                        addToCartBtn.addEventListener('click', async (e) => {
                            const productId = e.target.getAttribute('data-id');
                            const originalText = e.target.innerText;

                            const selectedAddons = Array.from(document.querySelectorAll('.addon-checkbox:checked'))
                                .map(cb => parseInt(cb.value));

                            e.target.innerText = 'Добавляем...';
                            e.target.disabled = true;

                            try {
                                const response = await fetch('/api/cart/add', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ product_id: productId, addons: selectedAddons })
                                });

                                const data = await response.json();
                                if (data.success) {
                                    e.target.innerText = 'В корзине ✓';
                                    e.target.style.backgroundColor = '#8CC63F';

                                    setTimeout(() => {
                                        e.target.innerText = originalText;
                                        e.target.disabled = false;
                                        e.target.style.backgroundColor = '#E30613';
                                    }, 2000);

                                    // Открываем боковую корзину
                                    if (typeof window.triggerSideCart === 'function') {
                                        window.triggerSideCart();
                                    }
                                } else {
                                    alert('Ошибка: ' + data.message);
                                    e.target.disabled = false;
                                    e.target.innerText = originalText;
                                }
                            } catch (err) {
                                console.error(err);
                                alert('Не удалось связаться с сервером');
                                e.target.disabled = false;
                                e.target.innerText = originalText;
                            }
                        });
                    }
                });
            </script>
</body>

</html>