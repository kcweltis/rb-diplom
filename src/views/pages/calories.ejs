<!doctype html>
<html lang="ru">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link rel="icon" type="image/png" href="/img/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/calories.css">
</head>

<body>
    <%- include('../partials/header') %>

        <main class="calWrap">
            <div class="container">

                <div class="calc-header">
                    <h1>Калькулятор калорий</h1>
                    <p>Узнайте свою рекомендуемую суточную норму калорий, а также посчитайте калорийность и содержание
                        белков, жиров и углеводов в выбранных блюдах.</p>
                </div>

                <div class="calc-menu-box">
                    <div class="calc-categories" id="calcCategories">
                        <button class="calc-cat-btn is-active" data-id="all">Все меню</button>
                        <% categories.forEach(c=> { %>
                            <button class="calc-cat-btn" data-id="<%= c.id %>">
                                <%= c.title %>
                            </button>
                            <% }) %>
                    </div>

                    <div class="calc-products-grid" id="calcProductsGrid">
                        <% products.forEach(p=> { %>
                            <div class="calc-prod-card" data-cat="<%= p.category_id %>">
                                <img src="<%= p.image_url || '/img/products/placeholder.png' %>" class="calc-prod-img"
                                    alt="<%= p.name %>">
                                <button class="calc-add-btn" data-id="<%= p.id %>" data-name="<%= p.name %>"
                                    data-img="<%= p.image_url || '/img/products/placeholder.png' %>"
                                    data-p="<%= p.proteins || 0 %>" data-f="<%= p.fats || 0 %>"
                                    data-c="<%= p.carbs || 0 %>" data-k="<%= p.calories || 0 %>">+</button>
                                <div class="calc-prod-title">
                                    <%= p.name %>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                </div>

                <div class="calc-workspace">
                    <div>
                        <div class="calc-summary-box">
                            <div class="calc-summary-title">Энергетическая ценность меню</div>
                            <div class="calc-nutri-row"><span>Белки, г.</span><span class="calc-nutri-val"
                                    id="totP">0.0</span></div>
                            <div class="calc-nutri-row"><span>Жиры, г.</span><span class="calc-nutri-val"
                                    id="totF">0.0</span></div>
                            <div class="calc-nutri-row"><span>Углеводы, г.</span><span class="calc-nutri-val"
                                    id="totC">0.0</span></div>
                            <div class="calc-total-kcal" id="totK">0</div>
                            <div class="calc-total-lbl">ККАЛ.</div>
                            <button class="btn btn--outline" style="width: 100%; border-radius: 99px; font-size: 12px;"
                                id="clearCalcBtn">Удалить все блюда</button>
                        </div>

                        <div class="calc-summary-box">
                            <div class="calc-summary-title">Ваша суточная норма</div>
                            <div class="calc-total-kcal" id="userNormValue">?</div>
                            <div class="calc-total-lbl">ККАЛ.</div>
                            <button class="btn btn--primary"
                                style="width: 100%; border-radius: 99px; font-size: 12px; background: #E30613;"
                                id="openNormModalBtn">Узнать мою норму</button>
                        </div>
                    </div>

                    <div class="calc-selected-list" id="selectedItemsList">
                        <div
                            style="grid-column: 1 / -1; text-align: center; color: #999; padding: 40px; border: 2px dashed #ddd; border-radius: 16px;">
                            Вы пока не добавили ни одного блюда.<br>Нажмите на <b>зеленый плюсик</b> в меню выше!
                        </div>
                    </div>
                </div>

            </div>
        </main>

        <div class="norm-modal" id="normModal">
            <div class="norm-modal-content">
                <button class="norm-close" id="closeNormModalBtn">&times;</button>
                <h2 style="font-family: 'Manrope'; margin: 0 0 20px;">Расчет нормы калорий</h2>

                <div class="form-group" style="margin-bottom: 16px;">
                    <label class="label" style="font-size: 12px;">Пол</label>
                    <div style="display: flex; gap: 20px; margin-top: 8px;">
                        <label style="cursor: pointer;"><input type="radio" name="calcGender" value="f" checked
                                accent-color="#E30613"> Женский</label>
                        <label style="cursor: pointer;"><input type="radio" name="calcGender" value="m"
                                accent-color="#E30613"> Мужской</label>
                    </div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 16px;">
                    <div><label class="label" style="font-size: 12px;">Возраст (лет)</label><input type="number"
                            id="calcAge" class="input" placeholder="Напр. 25"></div>
                    <div><label class="label" style="font-size: 12px;">Вес (кг)</label><input type="number"
                            id="calcWeight" class="input" placeholder="Напр. 65"></div>
                </div>
                <div class="form-group" style="margin-bottom: 16px;">
                    <label class="label" style="font-size: 12px;">Рост (см)</label>
                    <input type="number" id="calcHeight" class="input" placeholder="Напр. 170" style="width: 100%;">
                </div>
                <div class="form-group" style="margin-bottom: 24px;">
                    <label class="label" style="font-size: 12px;">Физическая активность</label>
                    <select id="calcActivity" class="input" style="width: 100%;">
                        <option value="1.2">Минимум/отсутствует</option>
                        <option value="1.375">Слабая (тренировки 1-3 раза в неделю)</option>
                        <option value="1.55">Средняя (тренировки 3-5 раз в неделю)</option>
                        <option value="1.725">Высокая (тренировки 6-7 раз в неделю)</option>
                    </select>
                </div>
                <button class="btn btn--primary" style="width: 100%; background: #E30613;"
                    id="calculateNormBtn">Рассчитать</button>
            </div>
        </div>

        <script>const PRODUCTS = <% - JSON.stringify(products) %>;</script>
        <script src="/js/calories.js"></script>

        <%- include('../partials/footer') %>
</body>

</html>