<!doctype html>
<html lang="ru">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    <%= title %>
  </title>
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Philosopher:wght@400;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
  <%- include('../partials/header', { isHome: true }) %>
    <main class="page page-home">

      <section class="hero-slider-section">
        <div class="hero-slider" id="heroSlider">
          <% if (typeof banners !=='undefined' && banners.length> 0) { %>
            <% banners.forEach((banner, index)=> { %>
              <div class="slide <%= index === 0 ? 'active' : '' %>"
                style="background-image: url('<%= banner.image_url %>')"></div>
              <% }) %>
                <% } else { %>
                  <div class="slide active" style="background-image: url('/img/banner1.jpg')"></div>
                  <% } %>
        </div>

        <div class="hero-content container">
          <h1 class="hero-title">
            Готовим<br>
            для Вас с<br>
            <span class="text-brand">душой</span>!
          </h1>
          <div class="hero-actions">
            <a href="/delivery" class="btn btn--outline"
              style="background: rgba(255,255,255,0.9); color: #333; border-color: transparent;">ДОСТАВКА</a>
            <a href="/menu" class="btn btn--primary">МЕНЮ</a>
          </div>
        </div>
      </section>

      <section class="section container">
        <div class="section__head">
          <h2 class="section__title">Популярные блюда</h2>
        </div>

        <div class="cards">
          <% if (featured && featured.length) { %>
            <% featured.forEach(p=> { %>
              <article class="card">
                <img class="card__img" src="<%= p.image_url || '/img/products/placeholder.png' %>" alt="<%= p.name %>">
                <div class="card__body">
                  <h3 class="card__title">
                    <%= p.name %>
                  </h3>
                  <div class="card__bottom">
                    <span class="card__price">
                      <%= Number(p.price).toFixed(0) %> руб.
                    </span>
                    <a class="btn btn--pill" href="/menu">В корзину</a>
                  </div>
                </div>
              </article>
              <% }) %>
                <% } else { %>
                  <p class="muted">Администратор ещё не выбрал популярные блюда. Добавь их в админке → «Популярные
                    блюда».</p>
                  <% } %>
        </div>

        <div class="section__cta">
          <a class="btn btn--primary" href="/menu">Перейти в меню</a>
        </div>
      </section>

      <section class="delivery-block">
        <div class="container delivery-block__inner">
          <div class="delivery-block__text">
            <h2 class="section__title">Собственная доставка</h2>
            <p class="muted">Мы доставляем заказы собственной курьерской службой — без посредников и дополнительных
              комиссий.</p>
          </div>
          <img class="delivery-block__icon" src="/img/icons/courier.png" alt="">
        </div>
      </section>

      <section class="section container">
        <h2 class="section__title section__title--center">Как сделать заказ</h2>

        <div class="steps">
          <div class="step">
            <div class="step__icon">🛒</div>
            <div class="step__text">Выберите блюда</div>
          </div>
          <div class="step">
            <div class="step__icon">🧾</div>
            <div class="step__text">Оформите заказ</div>
          </div>
          <div class="step">
            <div class="step__icon">👨‍🍳</div>
            <div class="step__text">Мы приготовим</div>
          </div>
          <div class="step">
            <div class="step__icon">🚴</div>
            <div class="step__text">Курьер доставит</div>
          </div>
        </div>
      </section>

      <section class="worktime">
        РАБОТАЕМ С ДУШОЙ КАЖДЫЙ ДЕНЬ С 10.00 ДО 22.00
      </section>
    </main>
    <%- include('../partials/footer') %>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const slides = document.querySelectorAll('.hero-slider .slide');
          if (slides.length === 0) return;

          let currentSlide = 0;
          const slideInterval = 4000;

          setInterval(() => {
            slides[currentSlide].classList.remove('active');
            currentSlide = (currentSlide + 1) % slides.length;
            slides[currentSlide].classList.add('active');
          }, slideInterval);
        });
      </script>
</body>

</html>