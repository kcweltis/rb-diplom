<!doctype html>
<html lang="ru" id="top">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    <%= title %>
  </title>
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Philosopher:wght@400;700&display=swap"
    rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/menu.css">
  <link rel="stylesheet" href="/css/footer.css">
</head>

<body>
  <%- include('../partials/header') %>

    <main class="menuWrap">
      <div class="container">
        <h1 class="menuTitle" style="margin-bottom: 40px;">НАШЕ МЕНЮ</h1>

        <div class="menuLayout">
          <aside class="menuAside">
            <form class="menuSearch" method="GET" action="/menu">
              <input class="menuSearch__input" name="q" value="<%= q %>" placeholder="Поиск по меню">
              <button class="menuSearch__btn" type="submit">Найти</button>
            </form>

            <nav class="catNav">
              <% categories.forEach((c)=> { %>
                <a class="catNav__link" href="#cat-<%= c.id %>" data-cat="<%= c.id %>">
                  <%= c.title %>
                </a>
                <% }) %>

                  <a class="catNav__link catNav__link--calc" href="/calories"
                    style="margin-top: 20px; color: #E30613; border: 1px solid #E30613; background: transparent; text-align: center;">
                    Калькулятор калорий →
                  </a>
            </nav>
          </aside>

          <section class="menuContent">
            <% categories.forEach(c=> {
              const list = byCat.get(c.id) || [];
              if (!list.length) return;
              %>
              <section class="catBlock" id="cat-<%= c.id %>">
                <h2 class="catTitle">
                  <%= c.title %>
                </h2>

                <div class="itemsGrid">
                  <% list.forEach(p=> { %>
                    <article class="itemCard open-modal-btn" data-id="<%= p.id %>" style="cursor: pointer;">
                      <div class="itemCard__imgBox">
                        <img class="itemCard__img" src="<%= p.image_url || '/img/products/placeholder.png' %>"
                          alt="<%= p.name %>">
                      </div>

                      <div class="itemCard__name">
                        <%= p.name %>
                      </div>

                      <div class="itemCard__meta">
                        <% if (p.weight_g || p.calories) { %>
                          <% if (p.weight_g) { %>
                            <span>
                              <%= p.weight_g %> г
                            </span>
                            <% } %>

                              <% if (p.weight_g && p.calories) { %>
                                <span>·</span>
                                <% } %>

                                  <% if (p.calories) { %>
                                    <span>
                                      <%= p.calories %> ккал
                                    </span>
                                    <% } %>
                                      <% } else { %>
                                        <span class="muted">нет данных</span>
                                        <% } %>
                      </div>

                      <div class="itemCard__bottom">
                        <div class="itemPrice">
                          <%= Number(p.price).toFixed(0) %> ₽
                        </div>

                        <button class="itemBtn" type="button">
                          Выбрать
                        </button>
                      </div>
                    </article>
                    <% }) %>
                </div>
              </section>
              <% }) %>
          </section>
        </div>
      </div>
    </main>

    <div class="prod-modal-overlay" id="prodModalOverlay">
      <div class="prod-modal">
        <button class="prod-modal__close" id="prodModalClose">✕</button>
        <div class="prod-modal__content" id="prodModalContent">
          <div style="text-align:center; padding: 40px;">Загрузка...</div>
        </div>
      </div>
    </div>

    <button class="floating-cart-btn" id="floatingCartBtn">
      🛒 Корзина
    </button>

    <div class="side-cart-overlay" id="sideCartOverlay"></div>
    <aside class="side-cart" id="sideCart">
      <div class="side-cart__header">
        <h2 style="margin:0; font-size: 24px;">Ваш заказ</h2>
        <button class="side-cart__close" id="closeSideCartBtn">✕</button>
      </div>

      <div class="side-cart__body" id="sideCartBody">
        <div style="text-align:center; margin-top: 40px; color: #666;">Загрузка...</div>
      </div>

      <div class="side-cart__footer">
        <div
          style="display: flex; justify-content: space-between; font-weight: 700; font-size: 20px; margin-bottom: 16px;">
          <span>Итого:</span>
          <span id="sideCartTotal">0 ₽</span>
        </div>
        <a href="/cart" class="btn btn--primary" style="width: 100%; text-align: center;">Оформить заказ</a>
      </div>
    </aside>

    <%- include('../partials/footer') %>

      <script src="/js/side-cart.js"></script>
      <script src="/js/menu.js"></script>
</body>

</html>